{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": ["error", { 
      "argsIgnorePattern": "^_", 
      "varsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_"
    }]
  },
  "ignorePatterns": [
    "public/sw.js",
    "public/workbox-*.js",
    "public/generate-icons.js",
    "node_modules/",
    ".next/",
    "dist/",
    "build/"
  ]
}
