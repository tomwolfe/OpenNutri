# ===========================================
# OpenNutri Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -------------------------------------------
# Authentication (NextAuth v5)
# -------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Password hashing salt rounds (bcrypt)
PASSWORD_HASH_SALT_ROUNDS=12

# -------------------------------------------
# Database (NeonDB Serverless Postgres)
# -------------------------------------------
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@host.neon.tech/opennutri?sslmode=require

# -------------------------------------------
# Storage (Vercel Blob)
# -------------------------------------------
# Get from Vercel project settings
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# -------------------------------------------
# AI Vision (Zhipu GLM)
# -------------------------------------------
# Get from https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here

# -------------------------------------------
# Food Data APIs (Optional for Phase 1)
# -------------------------------------------
# USDA FoodData Central API key (free)
USDA_API_KEY=your-usda-api-key-here

# OpenFoodFacts API (no key required, but rate limited)
# OPENFOODFACTS_API_URL=https://world.openfoodfacts.org

# -------------------------------------------
# Application Settings
# -------------------------------------------
# AI scan limit per day for free users
AI_SCAN_LIMIT_FREE=5

# Cron job authentication secret (generate with: openssl rand -base64 32)
CRON_SECRET=your-cron-secret-key-here

# Node environment
NODE_ENV=development
