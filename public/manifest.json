{
  "name": "OpenNutri - Privacy-Centric Nutrition Tracker",
  "short_name": "OpenNutri",
  "description": "Zero-friction nutrition logging with Vision AI",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#000000",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/icon-192x192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512x512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "categories": ["health", "lifestyle", "productivity"],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Log Food",
      "short_name": "Log",
      "description": "Quickly log a meal",
      "url": "/dashboard?action=log",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Snap to Log",
      "short_name": "Snap",
      "description": "Take a photo to log food",
      "url": "/dashboard?action=snap",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "files": [
        {
          "name": "food-image",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
